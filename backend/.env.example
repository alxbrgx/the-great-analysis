# Copy this file to .env and fill in your values

# App
APP_ENV=development
SECRET_KEY=change-me-in-production

# Database (optional for dev — SQLite used by default)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tga_db

# Redis (optional for dev — in-memory cache used by default)
REDIS_URL=redis://localhost:6379

# Financial Data APIs (free tiers)
FMP_API_KEY=your_fmp_key_here          # financialmodelingprep.com — free: 250 req/day
ALPHA_VANTAGE_KEY=your_av_key_here     # alphavantage.co — free: 25 req/day
FRED_API_KEY=your_fred_key_here        # fred.stlouisfed.org — free, generous limits

# Future paid tiers (leave empty for now)
POLYGON_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
